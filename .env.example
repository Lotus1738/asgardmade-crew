# ─── AsgardMade Pantheon — Environment Variables ───────────────────────────

# Anthropic (Claude) — Powers all agent intelligence and ODIN chat
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (DALL-E 3) — Powers Vulcan design generation
OPENAI_API_KEY=sk-...

# Etsy API — Powers Loki listing creation and Athena analytics
ETSY_API_KEY=
ETSY_SHOP_ID=

# Printify API — Powers Vulcan product uploads
PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=

# Serper API — Powers Heimdall Google search research (get key at serper.dev)
SERPER_API_KEY=

# Obsidian vault path (local only — leave blank on Railway)
OBSIDIAN_VAULT_PATH=C:\Users\YourName\AsgardMade HQ

# Pinterest — auto-pin new Etsy listings (get token at developers.pinterest.com)
PINTEREST_TOKEN=
PINTEREST_BOARD_ID=

# Discord — webhook notifications for sales, approvals, and daily briefing
# Create a webhook in your Discord server: Channel Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Twilio SMS — daily briefing to your phone (get credentials at twilio.com/console)
# TWILIO_ACCOUNT_SID starts with "AC"; phone numbers must be in E.164 format (+15551234567)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Redbubble — no public API; manual upload required
# REDBUBBLE_SHOP_URL=https://www.redbubble.com/portfolio/manage_works/add_new

# Amazon Merch by Amazon — no public API; invite-only program, manual upload required
# Apply at https://merch.amazon.com

# Server (Railway sets PORT automatically)
PORT=8000
